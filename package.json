{
  "name": "engineering-workspace",
  "displayName": "Engineering Workspace",
  "description": "Structured, visual SDLC workflow management for AI-assisted development in Code Studio.",
  "version": "0.1.0",
  "publisher": "syncfusion",
  "license": "MIT",
  "engines": {
    "vscode": "^1.93.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other",
    "Chat",
    "Machine Learning"
  ],
  "main": "./out/extension.js",
  "browser": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "engineering-workspace",
          "title": "Engineering Workspace",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "engineering-workspace": [
        {
          "type": "webview",
          "id": "engineeringWorkspace.mainView",
          "name": "Engineering Workspace",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "engineeringWorkspace.openView",
        "title": "Engineering Workspace: Open",
        "category": "Engineering Workspace"
      },
      {
        "command": "engineeringWorkspace.analyzeWorkRequest",
        "title": "Engineering Workspace: Analyze Work Request",
        "category": "Engineering Workspace"
      },
      {
        "command": "engineeringWorkspace.showHistory",
        "title": "Engineering Workspace: Show History",
        "category": "Engineering Workspace"
      }
    ],
    "chatParticipants": [
      {
        "id": "engineering-workspace.participant",
        "name": "engineering",
        "fullName": "Engineering Workspace",
        "description": "Manage structured SDLC workflows for AI-assisted development.",
        "isSticky": true,
        "commands": [
          {
            "name": "status",
            "description": "Show current workflow status"
          },
          {
            "name": "analyze",
            "description": "Analyze a work request objective"
          },
          {
            "name": "history",
            "description": "Show recent workflow history"
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "analyze_work_request",
        "description": "Analyze a work request objective and return a risk assessment (work type, complexity, risk signals, recommended process level).",
        "tags": [
          "engineering",
          "risk-assessment"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "objective": {
              "type": "string",
              "description": "The work request objective to analyze."
            },
            "context": {
              "type": "object",
              "description": "Optional project context signals.",
              "properties": {
                "touchesUi": {
                  "type": "boolean"
                },
                "touchesApi": {
                  "type": "boolean"
                },
                "touchesDatabase": {
                  "type": "boolean"
                }
              }
            }
          },
          "required": [
            "objective"
          ]
        }
      },
      {
        "name": "get_workflow_status",
        "description": "Return the current workflow state — active stage, completed stages, pending stages, and any pending approvals.",
        "tags": [
          "engineering",
          "workflow"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "includeHistory": {
              "type": "boolean",
              "description": "Include recent history entries in the response."
            }
          }
        }
      },
      {
        "name": "get_project_context",
        "description": "Return the auto-generated project context — detected stack, conventions, and relevant context signals.",
        "tags": [
          "engineering",
          "context"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext ts,tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "package": "vsce package --no-yarn"
  },
  "dependencies": {
    "@preact/signals": "^1.3.1",
    "@vscode/chat-extension-utils": "^0.0.0-alpha.5",
    "@vscode/codicons": "^0.0.36",
    "@vscode/prompt-tsx": "^0.4.0-alpha.1",
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.1",
    "@types/node": "^20.16.5",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^3.2.7",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.1.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vitest": "^3.2.7"
  }
}
